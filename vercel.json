{
  "cleanUrls": true,
  "outputDirectory": "dist/babybliss-frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-production-bddd.up.railway.app/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://backend-production-bddd.up.railway.app/storage/:path*"
    }
  ]
}
