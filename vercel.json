{
  "cleanUrls": true,
  "outputDirectory": "dist/babybliss-frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_BACKEND_URL/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://YOUR_BACKEND_URL/storage/:path*"
    }
  ]
}
